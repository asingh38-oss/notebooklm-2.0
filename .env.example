# Required — OpenAI API key for chat, embeddings, artifact generation, and TTS
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Required — simple app login credentials
# Format: username:password pairs separated by commas
USERS=demo:demo

# Optional — chunking settings (defaults shown)
CHUNK_SIZE=800
CHUNK_OVERLAP=150
EMBED_MODEL=text-embedding-3-small

# Optional — model and voice overrides
OPENAI_MODEL=gpt-4o
OPENAI_PODCAST_VOICE=alloy
